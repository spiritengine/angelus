# SKEIN local state — registered globally via ~/.skein/projects.json
.skein/

# Python / Node / etc. — pre-populate as the project grows
__pycache__/
*.pyc
.venv/
node_modules/
*.egg-info/
.pytest_cache/

# Angelus runtime state. Ignore everything under state/ (including the live,
# secret-adjacent state/angelus.env) but keep the checked-in env template.
state/*
!state/angelus.env.example
!state/sre-reports/
state/sre-reports/*
!state/sre-reports/.gitkeep
!state/digest-staging/
state/digest-staging/*
!state/digest-staging/.gitkeep
observations/
findings/
dispatches.log

# Editor / OS noise
*~
*#
.#*
.DS_Store

# Patrick's scratch
topost
