# Angelus non-secret runtime config (B16) -- single source of truth.
#
# Copy this file to state/angelus.env and fill in real values:
#     cp state/angelus.env.example state/angelus.env
#
# state/angelus.env is gitignored; this .example is the checked-in template.
# It holds NON-SECRETS only. The SMTP password is a real secret and does NOT
# belong here (see B20). Loaded by the daemon and the belfry the same way no
# matter how they start:
#   - systemd: deploy/angelus.service has EnvironmentFile=.../state/angelus.env
#   - cron:    belfry/crontab.example sources this file
#   - in code: the daemon and belfry both load it at startup (defends against
#              a hand-launch outside systemd -- the 2026-05-29 incident)
#
# Precedence: an explicitly-set environment variable ALWAYS wins over this
# file. Nothing here overwrites a name already present in the environment
# (systemd Environment=, a var exported in the shell/crontab, etc.).
#
# Format: KEY=value per line, '#' comments, blank lines ignored. Both systemd
# EnvironmentFile= and a shell `set -a; . file` parse this. Values are double
# quoted so a placeholder containing shell metacharacters (the '<...>' below)
# doesn't trip up the shell-sourcing path; the quotes are stripped on load.
# No shell expansion is performed.

# --- Delivery ---------------------------------------------------------------
# Recipient for the email channel (daily digest). Not used by belfry's notify().
ANGELUS_EMAIL_TO="you@example.com"

# --- Belfry healthchecks.io pings ------------------------------------------
# Register both URLs per belfry/healthchecks.example.
ANGELUS_BELFRY_SUCCESS_URL="https://hc-ping.com/<angelus-belfry-ping-uuid>"
ANGELUS_BELFRY_DOWN_URL="https://hc-ping.com/<angelus-daemon-down-uuid>"

# --- Thresholds / knobs (optional; defaults shown) --------------------------
# Belfry wedge threshold in seconds (default 600). Should comfortably exceed
# your longest source cadence so a quiet stretch isn't read as wedged
# (e.g. 18000 = 5h for a deployment whose slowest source fires every 4h).
# ANGELUS_BELFRY_WEDGE_THRESHOLD_SEC=600

# How stale the belfry sentinel may get before the daemon's health view calls
# belfry stale, in seconds (default 1200).
# ANGELUS_BELFRY_STALE_AFTER_SEC=1200

# Push command belfry shells out to on a DOWN condition (default 'notify-pat'
# on PATH). Alerts go over push, not email, so a dead email transport can't
# swallow the alert. Use an absolute path under cron, where PATH is stripped.
# ANGELUS_BELFRY_NOTIFY_COMMAND=/absolute/path/to/notify-pat

# Override paths for belfry's state files. Leave unset unless state/ is not
# writable.
# ANGELUS_BELFRY_SENTINEL_PATH=/var/lib/angelus/belfry-pinged-at
# ANGELUS_BELFRY_FAILCHECK_PATH=/var/lib/angelus/belfry-failcheck-at
